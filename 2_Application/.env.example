GOOGLE_API_KEY=

# Gemini model selection (fast default)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_REASONING_MODEL=gemini-2.5-pro

# ADK model for agents (overrides per-agent defaults)
# TRACE_MODEL_ID=gemini-2.5-flash

# Rate limiting for Gemini API (requests/minute)
GEMINI_RATE_LIMIT=60

# Response cache TTL in seconds
GEMINI_CACHE_TTL=300

# Flask server (set FLASK_DEBUG=1 only for local debugging — never in a demo/prod)
FLASK_ENV=development
FLASK_DEBUG=0

# React dev server API target (leave as-is for local dev)
VITE_API_URL=http://localhost:8000
