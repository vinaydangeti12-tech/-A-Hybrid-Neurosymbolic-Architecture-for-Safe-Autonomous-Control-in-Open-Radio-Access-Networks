# H-TRACE — environment configuration (EXAMPLE)
#
# 1. Copy this file to ".env"   (same folder)
# 2. Paste your real Gemini API key after the "=" below
# 3. NEVER commit your real .env file — it is git-ignored on purpose
#
# Get a free key at: https://aistudio.google.com/apikey

GEMINI_API_KEY=your_api_key_here

# Optional settings (sensible defaults are used if you leave these out):
# GEMINI_MODEL=gemini-2.5-flash   # which model the Smart Manager uses
# GEMINI_ENABLED=auto             # auto = use Gemini if a key is set; 0 = keyword only
